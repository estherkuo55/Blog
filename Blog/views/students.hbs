<div class="row">
  <div class="col-md-12">
    <h2>Posts <a href="/students/add" class="btn btn-success pull-right">Add Post</a> </h2>
    	
    <hr/>

    <div class="table-responsive-md">
      <table class="table">
        <thead>
          <tr>
            <th>Post&nbsp;ID</th>
            <th>Title</th>
            <th>Post&nbsp;Date</th>
            <th>Category</th>
            <th>Published</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each students}}
          <tr>
            <td> <a href="/student/{{this.studentID}}"> {{this.studentID}} </a></td>
            <td>  {{this.firstName}} {{this.lastName}} </td>
            <td>  <a href="mailto:{{this.email}}"> {{this.email}}</a></td>
            <td>{{this.addressStreet}} {{this.addressCity}} {{this.addressState}} {{this.addressPostal}}</td>
            <td> <a href="/students?credential={{this.expectedCredential}}"> {{this.expectedCredential}}</a></td>
            <td> <a href="/students?status={{this.status}}">  {{this.status}} </a></td>
            <td> <a href="/students?program={{this.program}}"> {{this.program}}</a></td>
            <td>{{this.registrationDate}}</td>
            <td><a href="/students/delete/{{studentID}}" class="btn btn-danger">remove</a></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{#unless students}}
        <div class="col-md-12 text-center">
            <strong>No post available</strong>
        </div>

    {{/unless}}

  </div>
</div>