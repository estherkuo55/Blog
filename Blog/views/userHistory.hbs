<!DOCTYPE html>
<html>
<head>
	<title>{{session.user.userName}} ({{session.user.email}}) History</title>
</head>
<body>
	<h2>{{session.user.userName}} ({{session.user.email}}) History</h2>
	<hr/>
	<div class="table-responsive-md">
		<table class="table">
			<thead>
				<tr>
					<th>Login Date/Time</th>
					<th>Client Information</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{{#each session.user.loginHistory}}
				<tr>
					<td>{{this.dateTime}}</td>
					<td>{{this.userAgent}}</td>
				</tr>
				{{/each}}
			</tbody>
		</table>
	</div>
</body>
</html>
