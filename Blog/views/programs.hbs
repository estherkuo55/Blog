<div class="row">
  <div class="col-md-12">
    <h2>Categories
      <a href="/programs/add" class="btn btn-success pull-right">Add Category</a>
    </h2>
    <hr />
    <div class="table-responsive-md">
      <table class="table">
        <thead>
          <tr>
            <th>Category ID</th>
            <th>Category Name</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each programs}}
          <tr>
            <td><a href="/program/{{this.programCode}}">{{this.programCode}}</a></td>
            <td><a href="/program/{{this.programCode}}">{{this.programName}}</a></td>
            {{!-- <td><a href="/program/{{this.programCode}}/edit" class="btn btn-warning">edit</a></td> --}}
            <td>
              <a href="/programs/delete/{{programCode}}" class="btn btn-danger " onsubmit="return confirm('Are you sure you want to delete this program?')">
                <button type="submit" class="btn btn-danger">remove</button>
              </form>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    <div>
      {{#unless programs}}
        <div class="col-md-12 text-center">
          <strong>No Category found.</strong>
        </div>
      {{/unless}}
    </div>
  </div>
</div>